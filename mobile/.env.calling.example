# Copy this to `.env` (or add to EAS secrets) and fill real TURN credentials.
# This is required for production-grade call reliability.

# Primary TURN
EXPO_PUBLIC_TURN_SERVER=turn.yourdomain.com:3478
EXPO_PUBLIC_TURN_USERNAME=replace_me_user
EXPO_PUBLIC_TURN_PASSWORD=replace_me_password

# Backup TURN
EXPO_PUBLIC_TURN_SERVER_2=turn-backup.yourdomain.com:3478
EXPO_PUBLIC_TURN_USERNAME_2=replace_me_user_2
EXPO_PUBLIC_TURN_PASSWORD_2=replace_me_password_2

# Reliability Flags
EXPO_PUBLIC_CALL_FORCE_RELAY=true
EXPO_PUBLIC_CALL_REQUIRE_CUSTOM_TURN=true
